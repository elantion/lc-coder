{
  "name": "lc-coder",
  "version": "0.1.0",
  "description": "小模型流水线编码工具 — 让小型 AI 模型也能高质量编码",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "lc-coder": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["ai", "coding", "cli", "small-model", "pipeline", "ollama", "gemma"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "ollama": "^0.6.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
